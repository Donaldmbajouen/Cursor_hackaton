PORT=3000
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=1
FRONTEND_URL=http://localhost:5173
# Origines CORS séparées par des virgules (ex. si Vite utilise 5174 car 5173 est pris)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
ENVIRONMENT=development
# PostgreSQL (Docker Compose : host = postgres)
DATABASE_URL=postgresql://votechain:votechain@localhost:5432/votechain
# Redis — compteurs de votes agrégés
REDIS_URL=redis://localhost:6379/0
VITE_API_URL=http://localhost:3000
